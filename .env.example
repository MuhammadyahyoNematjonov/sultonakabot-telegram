# ──────────────────────────────────────────────
# 🤖 TELEGRAM BOT SOZLAMALARI
# ──────────────────────────────────────────────

# Bot tokenini @BotFather dan oling:
# 1. Telegramda @BotFather ga yozing
# 2. /newbot buyrug'ini yuboring
# 3. Bot nomini kiriting (masalan: MyLawyerBot)
# 4. Bot username kiriting (masalan: my_lawyer_bot)
# 5. Token beriladi — quyiga ko'chiring
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAFxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# 👤 ADMIN SOZLAMALARI
# ──────────────────────────────────────────────

# Admin Telegram ID (bir yoki bir nechta, vergul bilan ajrating)
# ID olish uchun: @userinfobot ga /start yuboring
# Bir admin:   ADMIN_IDS=123456789
# Ko'p admin:  ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# Bot ichida admin login va parol
ADMIN_LOGIN=admin
ADMIN_PASSWORD=StrongP@ss123

# ──────────────────────────────────────────────
# 🗄️ DATABASE
# ──────────────────────────────────────────────

# SQLite fayl joylashuvi (o'zgartirmasangiz ham bo'ladi)
DATABASE_URL="file:./bot.db"
